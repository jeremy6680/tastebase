# frontend/.env.example
# Copy to .env.local (gitignored by Vite by default)

# FastAPI backend base URL (without trailing slash)
# In development, leave empty — Vite proxies /api → http://localhost:8000
# In production, set to your deployed API URL
VITE_API_BASE_URL=

VITE_DASHBOARD_URL=http://localhost:3000
VITE_AGENT_URL=http://localhost:8080
