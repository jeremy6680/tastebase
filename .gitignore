# =============================================================================
# TasteBase — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# User data (CSV exports and generated database — never commit personal data)
# -----------------------------------------------------------------------------
data/raw/
data/warehouse.duckdb
data/warehouse.duckdb.wal

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
.venv/
venv/
env/
.python-version

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
.dbt/
transform/target/
transform/logs/
transform/.user.yml
transform/dbt_packages/

# -----------------------------------------------------------------------------
# Chainlit
# -----------------------------------------------------------------------------
.chainlit/

# -----------------------------------------------------------------------------
# Evidence.dev
# -----------------------------------------------------------------------------
dashboard/.evidence/
dashboard/node_modules/
dashboard/.svelte-kit/
dashboard/build/

# -----------------------------------------------------------------------------
# Node / npm (frontend tooling)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.dockerignore

# -----------------------------------------------------------------------------
# Editors and OS
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains / PyCharm
.idea/
*.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Jupyter (if ever used for exploration)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb