# =============================================================================
# TasteBase — .dockerignore
# Excludes files and directories that should not be sent to the Docker daemon.
# Keeps the build context lean and prevents secrets from leaking into images.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and local config — never bake into an image
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# User data — mounted as volumes at runtime, not baked into images
# -----------------------------------------------------------------------------
data/raw/
data/warehouse.duckdb
data/warehouse.duckdb.wal
dashboard/sources/tastebase/warehouse.duckdb

# -----------------------------------------------------------------------------
# Python virtual environment and caches
# -----------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
.python-version
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# -----------------------------------------------------------------------------
# dbt artifacts (generated at runtime)
# -----------------------------------------------------------------------------
transform/target/
transform/logs/
transform/.user.yml
transform/dbt_packages/
.dbt/

# -----------------------------------------------------------------------------
# Node / frontend build artifacts
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/
dashboard/node_modules/
dashboard/.evidence/
dashboard/.svelte-kit/
dashboard/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# -----------------------------------------------------------------------------
# Chainlit session data
# -----------------------------------------------------------------------------
.chainlit/

# -----------------------------------------------------------------------------
# Editors and OS artifacts
# -----------------------------------------------------------------------------
.vscode/
*.code-workspace
.idea/
*.iml
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~

# -----------------------------------------------------------------------------
# Logs and test output
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Git history — not needed inside the image
# -----------------------------------------------------------------------------
.git/
.gitignore